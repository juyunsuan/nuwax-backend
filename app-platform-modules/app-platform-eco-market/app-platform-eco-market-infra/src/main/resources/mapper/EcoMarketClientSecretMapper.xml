<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xspaceagi.eco.market.spec.infra.dao.mapper.EcoMarketClientSecretMapper">

    <resultMap id="BaseResultMap" type="com.xspaceagi.eco.market.spec.infra.dao.entity.EcoMarketClientSecret">
            <id property="id" column="id" />
            <result property="name" column="name" />
            <result property="description" column="description" />
            <result property="clientId" column="client_id" />
            <result property="clientSecret" column="client_secret" />
            <result property="tenantId" column="_tenant_id" />
            <result property="created" column="created" />
            <result property="creatorId" column="creator_id" />
            <result property="creatorName" column="creator_name" />
            <result property="modified" column="modified" />
            <result property="yn" column="yn" />
    </resultMap>
 <!--后端业务逻辑,公共查询逻辑1-->
 <sql id="font_base_where">
    <if test="queryMap.authSpaceIds != null and queryMap.authSpaceIds.size > 0">
        and space_id in
        <foreach collection="queryMap.authSpaceIds" item="item" index="index" separator="," open="("
                 close=")">
            #{item}
        </foreach>
    </if>
    <if test="queryMap.spaceId != null">
        and space_id = #{queryMap.spaceId}
    </if>
    <if test="queryMap.name != null">
        and name like concat('%',#{queryMap.name},'%')
    </if>
    <if test="queryMap.dataType != null">
        and data_type = #{queryMap.dataType}
    </if>

    <include refid="SysCommonSql.base_where"></include>
    and yn = 1

</sql>
    <select id="queryTotal" resultType="java.lang.Long">
        select count(*)
        from eco_market_client_secret
        <where>
            <include refid="font_base_where"></include>
        </where>
    </select>

    <select id="queryList" resultMap="BaseResultMap">
        select
        *
        from eco_market_client_secret
        <where>
            <include refid="font_base_where"></include>
        </where>
        <choose>
            <when test="orderColumns != null and  orderColumns.size > 0">
                <foreach collection="orderColumns" item="entity" index="index" separator="," open="order by " close="">
                    <if test="entity != null">
                        ${entity.column}
                        <if test="!entity.asc">
                            desc
                        </if>
                    </if>
                </foreach>
            </when>
            <otherwise>
                order by created desc
            </otherwise>
        </choose>
        limit #{startIndex}, #{pageSize}
    </select>
</mapper>
