<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xspaceagi.system.infra.dao.mapper.SysOperatorLogMapper">

    <resultMap type="com.xspaceagi.system.infra.dao.entity.SysOperatorLog" id="BaseResultMap">
        <result property="id" column="id" jdbcType="INTEGER"/>
        <result property="operateType" column="operate_type" jdbcType="INTEGER"/>
        <result property="systemCode" column="system_code" jdbcType="VARCHAR"/>
        <result property="systemName" column="system_name" jdbcType="VARCHAR"/>
        <result property="objectOp" column="object_op" jdbcType="VARCHAR"/>
        <result property="action" column="action" jdbcType="VARCHAR"/>
        <result property="operateContent" column="operate_content" jdbcType="VARCHAR"/>
        <result property="extraContent" column="extra_content" jdbcType="CLOB"/>
        <result property="orgId" column="org_id" jdbcType="INTEGER"/>
        <result property="orgName" column="org_name" jdbcType="VARCHAR"/>
        <result property="creatorId" column="creator_id" jdbcType="INTEGER"/>
        <result property="creator" column="creator" jdbcType="VARCHAR"/>
        <result property="created" column="created" jdbcType="TIMESTAMP"/>
        <result property="modified" column="modified" jdbcType="TIMESTAMP"/>
        <result property="yn" column="yn" jdbcType="INTEGER"/>
    </resultMap>

    <!--后端业务逻辑,公共查询逻辑1-->
    <sql id="font_base_where">
        <if test="queryMap.systemCode != null and queryMap.systemCode.size > 0">
            and system_code in
            <foreach collection="queryMap.systemCode" item="item" index="index" separator="," open="("
                     close=")">
                #{item}
            </foreach>
        </if>
        <if test="queryMap.systemName != null and queryMap.systemName.size > 0">
            and system_name in
            <foreach collection="queryMap.systemName" item="item" index="index" separator="," open="("
                     close=")">
                #{item}
            </foreach>
        </if>
        <if test="queryMap.creatorId != null and queryMap.creatorId.size > 0">
            and creator_id in
            <foreach collection="queryMap.creatorId" item="item" index="index" separator="," open="("
                     close=")">
                #{item}
            </foreach>
        </if>
        <if test="queryMap.operateType != null">
            and operate_type = #{queryMap.operateType}
        </if>
        <if test="queryMap.action != null and queryMap.action.size > 0">
            and action in
            <foreach collection="queryMap.action" item="item" index="index" separator="," open="("
                     close=")">
                #{item}
            </foreach>
        </if>
        <!-- 操作方式 - 精确查询 -->
        <if test="queryMap.actionType != null and queryMap.actionType != ''">
            and action = #{queryMap.actionType}
        </if>
        <!-- 对象名称 - 模糊查询 -->
        <if test="queryMap.object != null and queryMap.object != ''">
            and object_op like concat('%',#{queryMap.object},'%')
        </if>
        <!-- 操作内容 - 模糊查询 -->
        <if test="queryMap.operateContent != null and queryMap.operateContent != ''">
            and operate_content like concat('%',#{queryMap.operateContent},'%')
        </if>
        <!-- 额外内容 - 模糊查询 -->
        <if test="queryMap.extraContent != null and queryMap.extraContent != ''">
            and extra_content like concat('%',#{queryMap.extraContent},'%')
        </if>
        <!-- 创建人名称 - 模糊查询 -->
        <if test="queryMap.creator != null and queryMap.creator != ''">
            and creator like concat('%',#{queryMap.creator},'%')
        </if>
        <include refid="SysCommonSql.base_where"></include>
        and yn = 1

    </sql>


    <select id="queryTotal" resultType="java.lang.Long">
        select count(*)
        from sys_operator_log
        <where>
            <include refid="font_base_where"></include>
        </where>
    </select>

    <select id="queryList" resultMap="BaseResultMap">
        select
        *
        from sys_operator_log
        <where>
            <include refid="font_base_where"></include>
        </where>
        <choose>
            <when test="orderColumns != null and  orderColumns.size > 0">
                <foreach collection="orderColumns" item="entity" index="index" separator="," open="order by " close="">
                    <if test="entity != null">
                        ${entity.column}
                        <if test="!entity.asc">
                            desc
                        </if>
                    </if>
                </foreach>
            </when>
            <otherwise>
                order by created desc
            </otherwise>
        </choose>
        limit #{startIndex}, #{pageSize}
    </select>


</mapper>
